    image_id          = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.AzureStackHCI/marketplaceGalleryImages/windows-server-2022-sql"
    processors        = 8
    memory_mb         = 32768
    os_disk_size_gb   = 256
    data_disk_size_gb = 1024
    tags = {
