resource_group_name = "rg-azure-local-vms"
location            = "eastus"
subscription_id     = "00000000-0000-0000-0000-000000000000"
tenant_id           = "00000000-0000-0000-0000-000000000000"

# Replace these IDs with values from your Azure Local environment.
custom_location_id   = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.ExtendedLocation/customLocations/azure-local-cl"
storage_container_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.AzureStackHCI/storageContainers/default"
logical_network_id   = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.AzureStackHCI/logicalNetworks/lnet-prod"
image_id             = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.AzureStackHCI/marketplaceGalleryImages/windows-server-2022"

dns_servers = ["10.0.0.10", "10.0.0.11"]

admin_username = "localadmin"

# Vault KV v2 secret location for the Windows local admin password.
# The secret should contain a key matching vault_admin_password_key.
vault_address                    = "https://vault.example.com"
vault_namespace                  = null
vault_admin_password_kv_mount    = "secret"
vault_admin_password_secret_name = "azure-local/windows-admin"
vault_admin_password_key         = "admin_password"

# Global tags applied to all resources
tags = {
  workload = "azure-local"
  managed  = "terraform"
}

compute_nodes = {
  "compute_01" = {
    name              = "win-app-01"
    private_ip        = "10.0.20.11"
    processors        = 4
    memory_mb         = 8192
    os_disk_size_gb   = 128
    data_disk_size_gb = 256
    tags = {
      role               = "app"
      notes              = "Primary application node"
      service_now_ticket = "CHG0000001"
    }
  }
  "compute_02" = {
    name              = "win-app-02"
    private_ip        = "10.0.20.12"
    image_id          = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-azure-local/providers/Microsoft.AzureStackHCI/marketplaceGalleryImages/windows-server-2022-app"
    processors        = 4
    memory_mb         = 8192
    os_disk_size_gb   = 128
    data_disk_size_gb = 512
    tags = {
      role               = "app"
      notes              = "Secondary application node"
      service_now_ticket = "CHG0000001"
    }
  }
  "compute_03" = {
    name              = "win-web-01"
    private_ip        = "10.0.20.13"
    processors        = 2
    memory_mb         = 4096
    os_disk_size_gb   = 96
    data_disk_size_gb = 128
    tags = {
      role               = "web"
      service_now_ticket = "CHG0000001"
    }
  }
  "compute_04" = {
